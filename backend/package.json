{
  "name": "noesis-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Noesis local-first learning backend (Express + SQLite + Ollama)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "migrate": "node -e \"require('./config/db').migrate()\"",
    "seed": "node scripts/seed-tutor-corpus.js",
    "seed:force": "node scripts/seed-tutor-corpus.js --force"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}

{
  "name": "noesis-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Noesis local-first learning backend (Express + SQLite + Ollama)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "migrate": "node -e \"require('./config/db').migrate()\"",
    "seed": "node scripts/seed-tutor-corpus.js",
    "seed:force": "node scripts/seed-tutor-corpus.js --force",
    "knowledge:validate": "node scripts/validate-knowledge.js",
    "knowledge:seed": "node scripts/seed-knowledge-corpus.js",
    "knowledge:seed:dry-run": "node scripts/seed-knowledge-corpus.js --dry-run",
    "eval:noesis": "node scripts/eval-noesis-generation.js",
    "eval:noesis:dry-run": "node scripts/eval-noesis-generation.js --dry-run",
    "eval:noesis:compare": "node scripts/eval-noesis-compare.js",
    "demo:check": "node scripts/demo-readiness-check.js",
    "eval:video": "node scripts/eval-video.js",
    "tts:check": "node scripts/tts-check.js",
    "tts:preview": "node scripts/tts-preview.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@remotion/bundler": "^4.0.443",
    "@remotion/renderer": "^4.0.443",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.443",
    "tesseract.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "canvas": "^3.2.3"
  },
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}

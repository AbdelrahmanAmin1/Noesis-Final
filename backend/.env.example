# --- Server ---
NODE_ENV=development
PORT=3001
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DATA_DIR=data
UPLOAD_DIR=uploads
DB_PATH=data/noesis.sqlite
MAX_UPLOAD_MB=25

# --- AI Provider ---
# ollama = local-only (default, no API key needed)
# groq   = optional cloud provider (fast, needs GROQ_API_KEY)
AI_PROVIDER=ollama

# --- Ollama (local, always used for embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEN_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=180000

# --- Groq (optional, only used when AI_PROVIDER=groq) ---
# Get your API key at https://console.groq.com
GROQ_API_KEY=
# Recommended models: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# --- Video pipeline ---
# TTS_ENGINE: piper (recommended, offline) | sapi (Windows built-in) | espeak | say | silence (explicit dev-only)
TTS_ENGINE=piper
# Path to Piper binary. On Windows: ./bin/piper.exe or full path
TTS_BIN=piper
# Path to a downloaded Piper voice model (.onnx file).
# Download from: https://huggingface.co/rhasspy/piper-voices/tree/main/en/en_US/amy/medium
# Place both .onnx and .onnx.json files in backend/tts-models/
TTS_VOICE_PATH=./tts-models/en_US-amy-medium.onnx
# FFmpeg/FFprobe paths. Leave as ffmpeg/ffprobe to use bundled static binaries first,
# with system PATH as a fallback.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Server ---
NODE_ENV=development
PORT=3001
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DATA_DIR=data
UPLOAD_DIR=uploads
DB_PATH=data/noesis.sqlite
MAX_UPLOAD_MB=25

# --- AI providers ---
# ollama = local-only default, no API key needed
# groq = optional cloud provider for demo-quality generation
AI_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
NOTES_PROVIDER=ollama
SUMMARY_PROVIDER=ollama
VIDEO_SCRIPT_PROVIDER=ollama
TUTOR_PROVIDER=groq
TUTOR_FALLBACK_PROVIDER=ollama
FLASHCARD_PROVIDER=groq
FLASHCARD_FALLBACK_PROVIDER=ollama
FLASHCARD_MAX_CARDS=6
FLASHCARD_TOP_K_CHUNKS=3
FLASHCARD_MAX_CONTEXT_CHARS=4000
FLASHCARD_TIMEOUT_MS=60000
TUTOR_VOICE_DEFAULT=true
TUTOR_TURN_RATE_LIMIT_PER_MIN=90
NOTES_AUDIO_PROVIDER=ollama
NOTES_AUDIO_FALLBACK_PROVIDER=ollama

# --- Curated knowledge context ---
KNOWLEDGE_CONTEXT_ENABLED=true
KNOWLEDGE_CONTEXT_MAX_CHARS=6000
KNOWLEDGE_USE_FOR_TUTOR=true
KNOWLEDGE_USE_FOR_NOTES=true
KNOWLEDGE_USE_FOR_VIDEO=true

# --- Optional Groq settings ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VIDEO_MAX_OUTPUT_TOKENS=4000
GROQ_NOTES_MAX_OUTPUT_TOKENS=2000

# --- Demo / video review ---
NOESIS_DEMO_MODE=true
VIDEO_RENDERER=canvas
STORYBOARD_REVIEW_REQUIRED=false
STRICT_QUALITY_GATES=false
VIDEO_RENDER_STRICT=true
LEARNING_MAP_LAYOUT=hybrid
LEARNING_MAP_ORIENTATION=hybrid

# --- TTS ---
# On Windows without Piper installed, set TTS_ENGINE=sapi for Windows Speech API
# On Linux without Piper, set TTS_ENGINE=espeak for espeak-ng fallback
TTS_ENGINE=sapi
TTS_BIN=piper
TTS_VOICE_PATH=./tts-models/en_US-lessac-medium.onnx
TTS_PAUSE_MS_SENTENCE=250
TTS_PAUSE_MS_SECTION=600
# Set to true to allow silent audio fallback when no TTS engine is available
NOESIS_ALLOW_SILENT_TTS=false

# --- Video rendering ---
VIDEO_SLIDE_MAX_BULLETS=5
VIDEO_AUDIO_NORMALIZE=true
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# --- Server ---
NODE_ENV=development
PORT=3001
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DATA_DIR=data
UPLOAD_DIR=uploads
DB_PATH=data/noesis.sqlite
MAX_UPLOAD_MB=25

# --- Ollama (LOCAL ONLY) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEN_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=180000

# --- Video pipeline ---
# TTS_ENGINE: piper (recommended, offline) | espeak | say
TTS_ENGINE=piper
TTS_BIN=piper
# Path to a downloaded Piper voice model (e.g. en_US-amy-low.onnx).
TTS_VOICE_PATH=
# Path or command for ffmpeg.
FFMPEG_PATH=ffmpeg

# --- Server ---
NODE_ENV=development
PORT=3001
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DATA_DIR=data
UPLOAD_DIR=uploads
DB_PATH=data/noesis.sqlite
MAX_UPLOAD_MB=25

# --- AI Provider ---
# ollama = local-only (default, no API key needed)
# groq   = optional cloud provider (fast, needs GROQ_API_KEY)
AI_PROVIDER=ollama

# --- Video script provider ---
# Mode 1 - Fully local:
# AI_PROVIDER=ollama
# VIDEO_SCRIPT_PROVIDER=ollama
# VIDEO_SCRIPT_GROQ_FALLBACK_ON_WEAK=false
#
# Mode 2 - Recommended: local-first with optional Groq fallback on weak video scripts:
# AI_PROVIDER=ollama
# VIDEO_SCRIPT_PROVIDER=ollama
# VIDEO_SCRIPT_GROQ_FALLBACK_ON_WEAK=true
# VIDEO_SCRIPT_MIN_QUALITY_SCORE=0.75
# GROQ_API_KEY=your_key_here
# GROQ_MODEL=openai/gpt-oss-120b
#
# Mode 3 - Direct Groq for video scripts only:
# AI_PROVIDER=ollama
# VIDEO_SCRIPT_PROVIDER=groq
# GROQ_API_KEY=your_key_here
# GROQ_MODEL=openai/gpt-oss-120b
#
# PRIVACY WARNING:
# If VIDEO_SCRIPT_GROQ_FALLBACK_ON_WEAK=true and GROQ_API_KEY is configured,
# retrieved chunks from uploaded materials may be sent to Groq ONLY when
# the local Ollama video script is weak or invalid.
#
# For fully local mode:
# VIDEO_SCRIPT_GROQ_FALLBACK_ON_WEAK=false
# VIDEO_SCRIPT_PROVIDER=ollama
#
# Embeddings always remain local with Ollama.
VIDEO_SCRIPT_PROVIDER=ollama
VIDEO_SCRIPT_GROQ_FALLBACK_ON_WEAK=false
VIDEO_SCRIPT_MIN_QUALITY_SCORE=0.75
VIDEO_SCRIPT_USE_LOCAL_IF_GROQ_FAILS=true

# --- Ollama (local, always used for embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEN_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=180000

# --- Groq (optional, only used when AI_PROVIDER=groq) ---
# Get your API key at https://console.groq.com
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
# Recommended for video fallback: openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VIDEO_MAX_OUTPUT_TOKENS=1000
GROQ_VIDEO_TOP_K_CHUNKS=4
GROQ_VIDEO_MAX_CHUNK_CHARS=900
GROQ_VIDEO_MAX_INPUT_CHARS=12000

# --- Video pipeline ---
# TTS_ENGINE: piper (recommended, offline) | sapi (Windows built-in) | espeak | say | silence (explicit dev-only)
TTS_ENGINE=piper
# Path to Piper binary. On Windows: ./bin/piper.exe or full path
TTS_BIN=piper
# Path to a downloaded Piper voice model (.onnx file).
# Download from: https://huggingface.co/rhasspy/piper-voices/tree/main/en/en_US/amy/medium
# Place both .onnx and .onnx.json files in backend/tts-models/
TTS_VOICE_PATH=./tts-models/en_US-amy-medium.onnx
# Narration pacing. Safe defaults work with SAPI and keep Piper/espeak/say compatible.
TTS_PAUSE_MS_SENTENCE=250
TTS_PAUSE_MS_SECTION=600
# Slide readability and final audio polish.
VIDEO_SLIDE_MAX_BULLETS=5
VIDEO_AUDIO_NORMALIZE=true
# FFmpeg/FFprobe paths. Leave as ffmpeg/ffprobe to use bundled static binaries first,
# with system PATH as a fallback.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

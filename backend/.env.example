# --- Server ---
NODE_ENV=development
PORT=3001
JWT_SECRET=change-me-please
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DATA_DIR=data
UPLOAD_DIR=uploads
DB_PATH=data/noesis.sqlite
MAX_UPLOAD_MB=25

# --- Local/demo rate limits ---
# Higher demo defaults prevent normal generation retries from showing http_429.
RATE_LIMITS_ENABLED=true
GLOBAL_RATE_LIMIT_PER_15_MIN=1000
AI_RATE_LIMIT_PER_MIN=120
VIDEO_RATE_LIMIT_PER_MIN=60
UPLOAD_RATE_LIMIT_PER_MIN=30
TTS_RATE_LIMIT_PER_MIN=60
TUTOR_TURN_RATE_LIMIT_PER_MIN=120
AUTH_RATE_LIMIT_PER_15_MIN=30

# --- AI providers ---
# Ollama is local-only. Groq is optional and requires a private API key.
NOESIS_DEMO_MODE=true
AI_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEN_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_MS=180000

GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VIDEO_MAX_OUTPUT_TOKENS=4000
GROQ_NOTES_MAX_OUTPUT_TOKENS=2000

# --- Feature providers ---
# Use ollama instead of groq below for a fully local configuration.
NOTES_PROVIDER=groq
SUMMARY_PROVIDER=groq
VIDEO_SCRIPT_PROVIDER=groq
TUTOR_PROVIDER=groq
TUTOR_FALLBACK_PROVIDER=ollama
QUIZ_PROVIDER=groq
QUIZ_FALLBACK_PROVIDER=ollama
QUIZ_GENERATION_TIMEOUT_MS=90000
FLASHCARD_PROVIDER=groq
FLASHCARD_FALLBACK_PROVIDER=ollama

# --- Flashcards ---
FLASHCARD_MIN_CARDS=6
FLASHCARD_MAX_CARDS=8
FLASHCARD_DEFAULT_CARDS=8
FLASHCARD_TOP_K_CHUNKS=3
FLASHCARD_MAX_CONTEXT_CHARS=4000
FLASHCARD_TIMEOUT_MS=60000

# --- Video and storyboard ---
VIDEO_RENDERER=remotion
STORYBOARD_REVIEW_REQUIRED=true
STRICT_QUALITY_GATES=true

# --- OCR and source visuals ---
# Optional fallback only: normal PDF/PPTX/text extraction still runs first.
# OCR_PROVIDER=ocrmypdf requires OCRmyPDF, Tesseract, and Poppler locally.
OCR_ENABLED=false
OCR_PROVIDER=ocrmypdf
OCR_MIN_TEXT_CHARS_PER_PAGE=250
OCR_TIMEOUT_MS=180000
OCR_MAX_PAGES=40
OCR_TESSERACT_LANG=eng
SOURCE_VISUALS_MAX_PER_MATERIAL=8

# --- Source grounding judge ---
SOURCE_GROUNDING_JUDGE_ENABLED=true
SOURCE_GROUNDING_JUDGE_MODE=deterministic
SOURCE_GROUNDING_JUDGE_RETRY_LIMIT=1
SOURCE_GROUNDING_JUDGE_BLOCK_ON_TOPIC_DRIFT=true
SOURCE_REPAIR_SAVE_SAFE_FALLBACK=true

# --- Local text-to-speech ---
TTS_ENGINE=piper
TTS_BIN=./bin/piper/piper/piper.exe
TTS_VOICE_PATH=./tts-models/en_US-lessac-medium.onnx
# Windows only, used when TTS_ENGINE=sapi (for example: Microsoft Zira Desktop)
TTS_SAPI_VOICE=
TTS_PAUSE_MS_SENTENCE=250
TTS_PAUSE_MS_SECTION=600

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noesis.local/schemas/knowledge-topic.schema.json",
  "title": "Noesis Curated Knowledge Topic",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "schemaVersion",
    "domain",
    "topic",
    "aliases",
    "difficulty",
    "prerequisites",
    "nextTopics",
    "definition",
    "deepExplanation",
    "whyItMatters",
    "analogy",
    "codeExamples",
    "diagrams",
    "commonMistakes",
    "bestPractices",
    "complexity",
    "miniQuiz",
    "flashcards",
    "visualTemplates",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "schemaVersion": {
      "const": 1
    },
    "domain": {
      "enum": ["oop", "data-structures", "algorithms", "big-o", "misconceptions", "general"]
    },
    "topic": {
      "type": "string",
      "minLength": 2
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "difficulty": {
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "nextTopics": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "definition": {
      "type": "string",
      "minLength": 30
    },
    "deepExplanation": {
      "type": "string",
      "minLength": 80
    },
    "whyItMatters": {
      "type": "string",
      "minLength": 40
    },
    "analogy": {
      "type": "string",
      "minLength": 40
    },
    "codeExamples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["language", "title", "code", "walkthrough"],
        "properties": {
          "language": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "code": { "type": "string", "minLength": 20 },
          "walkthrough": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["lineRange", "text"],
              "properties": {
                "lineRange": { "type": "string", "minLength": 1 },
                "text": { "type": "string", "minLength": 10 }
              }
            }
          }
        }
      }
    },
    "diagrams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "title", "nodes", "edges", "caption"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "nodes": { "type": "array", "minItems": 1 },
          "edges": { "type": "array" },
          "caption": { "type": "string", "minLength": 10 }
        }
      }
    },
    "commonMistakes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 10 },
          {
            "type": "object",
            "required": ["mistake", "correction"],
            "properties": {
              "mistake": { "type": "string", "minLength": 10 },
              "whyItHappens": { "type": "string" },
              "correction": { "type": "string", "minLength": 10 }
            }
          }
        ]
      }
    },
    "bestPractices": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 }
    },
    "complexity": {
      "anyOf": [
        { "type": "null" },
        { "type": "object" }
      ]
    },
    "miniQuiz": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["question", "answer", "explanation"],
        "properties": {
          "question": { "type": "string", "minLength": 10 },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "answer": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string", "minLength": 10 }
        }
      }
    },
    "flashcards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["front", "back"],
        "properties": {
          "front": { "type": "string", "minLength": 5 },
          "back": { "type": "string", "minLength": 10 },
          "difficulty": { "enum": ["easy", "medium", "hard"] }
        }
      }
    },
    "visualTemplates": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          { "type": "object" }
        ]
      }
    },
    "source": {
      "type": "object",
      "required": ["type", "license"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 }
      }
    }
  }
}
